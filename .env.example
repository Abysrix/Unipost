# Next.js Public Client Configuration (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Server-Only Configuration (Private keys, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Social Integrations Crypto Key (Required, 32-byte Base64 key for AES token encryption)
# You can generate one with: openssl rand -base64 32
INTEGRATIONS_SECRET_KEY=your-base64-32-byte-key

# Cron Job Auth Secret (Required for background workers, publish & sync automation)
CRON_SECRET=your-random-cron-secret-token

# AI content engine (OpenRouter API Key, OpenAI-compatible endpoint)
API_KEY=your-openrouter-api-key

# Payment Gateway (Razorpay INR checkout; optional, falls back to in-app mock checkout if empty)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email Delivery (Resend API; optional, falls back to server-log stubs if empty)
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=UniPost <notifications@unipost.bharvix.com>

# Webhooks & External Event Receivers
# Meta (Facebook/Instagram/Threads webhook signatures & GET handshakes)
META_WEBHOOK_VERIFY_TOKEN=your-meta-verify-token
META_APP_SECRET=
# X / Twitter (Account Activity API webhook signatures; uses Consumer Secret)
X_WEBHOOK_CONSUMER_SECRET=

# Social Integrations Client Credentials (Optional, empty triggers simulated consent screens)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
