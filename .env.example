# ─────────────────────────────────────────────────────────────
# UniPost AI — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (never exposed to the browser). Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The origin the app runs on (used for OAuth / email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Gemini (AI Studio) → https://aistudio.google.com/app/apikey
# Server-only. Required for the AI Studio chat, content tools and editor AI.
GEMINI_API_KEY=your-gemini-api-key

# Social Integrations (Sprint 7) — REQUIRED for /integrations to work at all.
# Any random 32+ char string. Encrypts stored OAuth tokens (AES-256-GCM) and
# signs the OAuth connect flow's CSRF state — both derived from this one
# secret via HKDF. Generate one: `openssl rand -base64 32`
INTEGRATIONS_SECRET_KEY=replace-with-a-long-random-secret

# Per-platform OAuth apps — all OPTIONAL. Without them, "Connect" still works
# end-to-end via a simulated consent screen (see lib/integrations/oauth.ts) so
# you can test the full flow before registering real developer apps. Add a
# platform's client id/secret here and it starts using the real provider —
# no code changes needed.
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# THREADS_CLIENT_ID=
# THREADS_CLIENT_SECRET=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TikTok/Pinterest are not connectable yet (config-only, Integration Sprint 2)
# — these don't do anything even if set until a future sprint wires up their
# connect UI. Listed here so the shape is documented ahead of time.
# TIKTOK_CLIENT_ID=
# TIKTOK_CLIENT_SECRET=
# PINTEREST_CLIENT_ID=
# PINTEREST_CLIENT_SECRET=

# Razorpay Billing (Sprint 8) — all OPTIONAL. Without them, checkout still
# works end-to-end via an in-app simulated payment modal (see lib/billing/
# razorpay.ts) so you can test upgrades/downgrades/cancellation before
# registering a real Razorpay account. Add these and checkout switches to real
# payments — no code changes needed.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# Only needed once you register a webhook URL in the Razorpay dashboard
# (Settings → Webhooks) for payment.captured / payment.failed events.
# RAZORPAY_WEBHOOK_SECRET=

# Optional — error tracking (Sprint 10). Leave unset to disable; the app runs
# identically either way (see lib/monitoring/logger.ts). No vendor lock-in:
# swap this for any provider without touching call sites.
# SENTRY_DSN=
